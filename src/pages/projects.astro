---
import '../styles/global.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import ProjectGallery from '../components/ProjectGallery.tsx';
---

<BaseLayout title="Projects — Jamel Estrella" description="All of Jamel's software projects.">
  <main class="max-w-screen-xl mx-auto px-4 sm:px-6 pt-10 pb-16">

    <!-- Prominent Back to Home button -->
    <div class="mb-10">
      <a
        href="/"
        class="inline-flex items-center gap-2.5 bg-white/5 backdrop-blur-md border border-purple-800/40 text-purple-300 px-5 py-2.5 rounded-full text-sm font-bold hover:bg-purple-900/40 hover:border-purple-600/60 hover:text-white transition-all group"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:-translate-x-0.5 transition-transform"><path d="m15 18-6-6 6-6"/></svg>
        Back to Home
      </a>
    </div>

    <div class="mb-8">
      <h1 class="text-3xl sm:text-4xl font-extrabold text-white">All Projects</h1>
      <p class="text-purple-300/45 mt-2 text-sm">Every piece of work I've shipped. Click to explore details.</p>
    </div>

    <ProjectGallery client:load showViewAll={false} />
  </main>
  <Footer />
</BaseLayout>
