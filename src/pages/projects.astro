---
import '../styles/global.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ProjectGallery from '../components/ProjectGallery.tsx';
---

<BaseLayout title="Projects — Jamel Estrella" description="All of Jamel's software projects.">
  <Header />
  <main class="max-w-screen-xl mx-auto px-4 sm:px-6 pt-28 sm:pt-32 pb-16">
    <div class="mb-10">
      <a
        href="/"
        class="inline-flex items-center gap-2 text-purple-400/70 hover:text-purple-300 text-sm font-medium transition-colors group mb-6"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:-translate-x-0.5 transition-transform"><path d="m15 18-6-6 6-6"/></svg>
        Back to Home
      </a>
      <h1 class="text-3xl sm:text-4xl font-extrabold text-white">All Projects</h1>
      <p class="text-purple-300/45 mt-2 text-sm">Every piece of work I've shipped. Click to explore details.</p>
    </div>

    <!-- Show all projects, no "View All" link -->
    <ProjectGallery client:load showViewAll={false} />
  </main>
  <Footer />
</BaseLayout>
