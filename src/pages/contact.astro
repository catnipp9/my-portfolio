---
import '../styles/global.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.tsx';
---

<BaseLayout title="Contact — Jamel Estrella" description="Get in touch with Jamel Estrella.">
  <!-- Top bar -->
  <div class="fixed top-0 left-0 right-0 z-50 px-4 sm:px-8 py-4">
    <a
      href="/"
      class="inline-flex items-center gap-2 bg-white/5 backdrop-blur-md border border-purple-800/40 text-purple-300 px-4 py-2 rounded-full text-sm font-bold hover:bg-purple-900/40 hover:border-purple-600/60 hover:text-white transition-all group"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:-translate-x-0.5 transition-transform"><path d="m15 18-6-6 6-6"/></svg>
      Back to Portfolio
    </a>
  </div>

  <main class="min-h-[100dvh] flex flex-col justify-center max-w-screen-xl mx-auto px-4 sm:px-6 pt-24 pb-16">

    <!-- Page heading -->
    <div class="text-center mb-12">
      <div class="inline-flex items-center gap-2 bg-purple-900/50 border border-purple-700/50 px-4 py-1.5 rounded-full text-purple-300 text-xs font-bold mb-5">
        <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
        Open to opportunities
      </div>
      <h1 class="text-3xl sm:text-5xl md:text-6xl font-extrabold text-white tracking-tight mb-4">
        Let's build something <span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-violet-400">together.</span>
      </h1>
      <p class="text-purple-200/50 text-base sm:text-lg max-w-xl mx-auto">
        Have a project, opportunity, or just want to say hi? Drop me a message below.
      </p>
    </div>

    <!-- Two-col grid -->
    <div class="grid lg:grid-cols-2 gap-8 lg:gap-12 items-start">

      <!-- LEFT: Form -->
      <ContactForm client:load />

      <!-- RIGHT: Info -->
      <div class="flex flex-col gap-6">

        <!-- Contact details card -->
        <div class="bg-white/5 border border-purple-800/30 rounded-[2rem] p-6 sm:p-8">
          <h3 class="text-lg font-bold text-white mb-6">Contact Information</h3>

          <ul class="flex flex-col gap-5">
            <!-- Email -->
            <li class="flex items-center gap-4">
              <div class="w-11 h-11 shrink-0 rounded-2xl bg-purple-900/60 border border-purple-700/40 flex items-center justify-center text-purple-300">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              </div>
              <div>
                <p class="text-xs font-bold text-purple-400 uppercase tracking-widest mb-0.5">Email</p>
                <a href="mailto:hello@jamel.dev" class="text-white text-sm font-medium hover:text-purple-300 transition-colors">hello@jamel.dev</a>
              </div>
            </li>

            <!-- Phone -->
            <li class="flex items-center gap-4">
              <div class="w-11 h-11 shrink-0 rounded-2xl bg-purple-900/60 border border-purple-700/40 flex items-center justify-center text-purple-300">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.3 2 2 0 0 1 3.6 1h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.5a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              </div>
              <div>
                <p class="text-xs font-bold text-purple-400 uppercase tracking-widest mb-0.5">Phone</p>
                <a href="tel:+639000000000" class="text-white text-sm font-medium hover:text-purple-300 transition-colors">+63 900 000 0000</a>
              </div>
            </li>

            <!-- Location -->
            <li class="flex items-center gap-4">
              <div class="w-11 h-11 shrink-0 rounded-2xl bg-purple-900/60 border border-purple-700/40 flex items-center justify-center text-purple-300">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12S4 16 4 10a8 8 0 1 1 16 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div>
                <p class="text-xs font-bold text-purple-400 uppercase tracking-widest mb-0.5">Location</p>
                <p class="text-white text-sm font-medium">Manila, Philippines</p>
              </div>
            </li>
          </ul>
        </div>

        <!-- Socials card -->
        <div class="bg-white/5 border border-purple-800/30 rounded-[2rem] p-6 sm:p-8">
          <h3 class="text-lg font-bold text-white mb-2">Find me online</h3>
          <p class="text-purple-300/40 text-xs mb-6">Let's connect on social media too.</p>

          <div class="flex flex-wrap gap-3">
            <!-- LinkedIn -->
            <a
              href="https://linkedin.com/"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-3 px-5 py-3 bg-[#0A66C2]/20 border border-[#0A66C2]/40 text-[#58A0D8] rounded-2xl text-sm font-bold hover:bg-[#0A66C2]/30 hover:border-[#0A66C2]/70 hover:scale-105 transition-all"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
              LinkedIn
            </a>

            <!-- GitHub -->
            <a
              href="https://github.com/"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-3 px-5 py-3 bg-white/5 border border-purple-800/50 text-purple-200 rounded-2xl text-sm font-bold hover:bg-white/10 hover:border-purple-600/60 hover:scale-105 transition-all"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
              GitHub
            </a>

            <!-- Discord -->
            <a
              href="https://discord.com/"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-3 px-5 py-3 bg-[#5865F2]/20 border border-[#5865F2]/40 text-[#8B97F7] rounded-2xl text-sm font-bold hover:bg-[#5865F2]/30 hover:border-[#5865F2]/70 hover:scale-105 transition-all"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057c.002.022.015.043.032.054a19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>
              Discord
            </a>
          </div>
        </div>

        <!-- Decorative map placeholder -->
        <div class="bg-white/5 border border-purple-800/30 rounded-[2rem] overflow-hidden h-40 sm:h-52 relative">
          <div class="absolute inset-0 flex items-center justify-center">
            <!-- Bubbly decorative map SVG -->
            <svg viewBox="0 0 400 200" class="w-full h-full opacity-30" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <radialGradient id="mapGlow" cx="50%" cy="50%" r="50%">
                  <stop offset="0%" stop-color="#7c3aed" stop-opacity="0.4"/>
                  <stop offset="100%" stop-color="#0d0a16" stop-opacity="0"/>
                </radialGradient>
              </defs>
              <rect width="400" height="200" fill="url(#mapGlow)"/>
              <!-- Grid lines -->
              {Array.from({length: 8}).map((_, i) => (
                <line x1={i * 50} y1="0" x2={i * 50} y2="200" stroke="#7c3aed" stroke-width="0.5" stroke-dasharray="4,8"/>
              ))}
              {Array.from({length: 5}).map((_, i) => (
                <line x1="0" y1={i * 50} x2="400" y2={i * 50} stroke="#7c3aed" stroke-width="0.5" stroke-dasharray="4,8"/>
              ))}
              <!-- Blobs -->
              <ellipse cx="200" cy="100" rx="60" ry="35" fill="#7c3aed" opacity="0.15" />
              <ellipse cx="160" cy="80" rx="30" ry="20" fill="#6d28d9" opacity="0.2" />
              <!-- Pin -->
              <circle cx="200" cy="100" r="6" fill="#a855f7"/>
              <circle cx="200" cy="100" r="12" fill="#a855f7" opacity="0.3"/>
              <circle cx="200" cy="100" r="20" fill="#a855f7" opacity="0.1"/>
            </svg>
          </div>
          <div class="absolute bottom-4 left-4 flex items-center gap-2 bg-purple-900/80 backdrop-blur border border-purple-700/50 px-3 py-1.5 rounded-full">
            <span class="w-2 h-2 rounded-full bg-purple-400"></span>
            <span class="text-xs font-bold text-purple-300">Manila, Philippines</span>
          </div>
        </div>

      </div>
    </div>
  </main>
</BaseLayout>
