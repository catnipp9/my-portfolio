---
import '../styles/global.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Footer from '../components/Footer.astro';
import SkillsCatalog from '../components/SkillsCatalog.tsx';
import ProjectGallery from '../components/ProjectGallery.tsx';
import CertificateGallery from '../components/CertificateGallery.tsx';
---

<BaseLayout>
  <Header />
  <main class="max-w-screen-xl mx-auto px-4 sm:px-6 pb-16">
    <Hero />
    <SkillsCatalog client:load />
    <!-- Show top 3 projects on home; link to /projects for all -->
    <ProjectGallery client:load limit={3} showViewAll={true} />
    <CertificateGallery client:load limit={3} showViewAll={true} />
  </main>
  <Footer />
</BaseLayout>
