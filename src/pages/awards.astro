---
import '../styles/global.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import CertificateGallery from '../components/CertificateGallery.tsx';
---

<BaseLayout title="Awards & Certifications — Jamel Hadjirasul" description="All of Jamel's awards and certifications.">
  <main class="min-h-[100dvh] flex flex-col max-w-screen-xl mx-auto px-4 sm:px-6 pt-5 sm:pt-6 pb-8">

    <!-- Back button -->
    <div class="mb-4">
      <a
        href="/"
        class="inline-flex items-center gap-2 bg-white/5 backdrop-blur-md border border-purple-800/40 text-purple-300 px-4 py-2 rounded-full text-xs font-bold hover:bg-purple-900/40 hover:border-purple-600/60 hover:text-white transition-all group"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:-translate-x-0.5 transition-transform"><path d="m15 18-6-6 6-6"/></svg>
        Back to Portfolio
      </a>
    </div>

    <!-- Heading -->
    <div class="mb-5">
      <h1 class="text-2xl sm:text-3xl md:text-4xl font-extrabold text-white tracking-tight">Awards & <span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-violet-400">Certifications</span></h1>
      <div class="flex items-center justify-between gap-4 mt-1.5">
        <p class="text-purple-200/45 text-sm">Every credential and recognition I've earned. Click any card to explore details.</p>
        <div class="inline-flex items-center gap-2 bg-purple-900/50 border border-purple-700/50 px-3 py-1 rounded-full text-purple-300 text-[10px] font-bold shrink-0 cursor-default transition-all duration-150 hover:bg-purple-800/60 hover:border-purple-500/70 hover:text-white hover:scale-105 active:scale-95">
          <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
          Always learning
        </div>
      </div>
    </div>

    <CertificateGallery client:load showViewAll={false} showSectionHeader={false} />
  </main>
  <Footer />
</BaseLayout>
