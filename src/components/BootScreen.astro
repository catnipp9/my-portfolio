<!-- Boot/Intro animation overlay — only shown once per session -->
<div id="boot-screen" class="fixed inset-0 z-[9999] flex flex-col items-center justify-center bg-[#0a0713] overflow-hidden">

  <!-- Star particles -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none" id="boot-stars"></div>

  <!-- Circuit glow rings -->
  <div class="relative flex items-center justify-center mb-8">
    <!-- Outer pulse ring -->
    <div class="absolute w-64 h-64 rounded-full border border-purple-500/20 animate-[boot-ring_2s_ease-in-out_infinite]"></div>
    <div class="absolute w-52 h-52 rounded-full border border-purple-500/30 animate-[boot-ring_2s_0.3s_ease-in-out_infinite]"></div>

    <!-- Circuit lines SVG -->
    <svg class="absolute w-80 h-80 opacity-30" viewBox="0 0 320 320" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Left lines -->
      <line x1="160" y1="160" x2="40" y2="160" stroke="#a855f7" stroke-width="1" stroke-dasharray="4 4" class="circuit-line"/>
      <line x1="40" y1="160" x2="10" y2="130" stroke="#a855f7" stroke-width="1" stroke-dasharray="4 4" class="circuit-line"/>
      <line x1="40" y1="160" x2="10" y2="190" stroke="#a855f7" stroke-width="1" stroke-dasharray="4 4" class="circuit-line"/>
      <circle cx="40" cy="160" r="3" fill="#a855f7"/>
      <circle cx="10" cy="130" r="3" fill="#a855f7"/>
      <circle cx="10" cy="190" r="3" fill="#a855f7"/>
      <!-- Right lines -->
      <line x1="160" y1="160" x2="280" y2="160" stroke="#a855f7" stroke-width="1" stroke-dasharray="4 4" class="circuit-line"/>
      <line x1="280" y1="160" x2="310" y2="130" stroke="#a855f7" stroke-width="1" stroke-dasharray="4 4" class="circuit-line"/>
      <line x1="280" y1="160" x2="310" y2="190" stroke="#a855f7" stroke-width="1" stroke-dasharray="4 4" class="circuit-line"/>
      <circle cx="280" cy="160" r="3" fill="#a855f7"/>
      <circle cx="310" cy="130" r="3" fill="#a855f7"/>
      <circle cx="310" cy="190" r="3" fill="#a855f7"/>
      <!-- Top lines -->
      <line x1="160" y1="160" x2="160" y2="40" stroke="#a855f7" stroke-width="1" stroke-dasharray="4 4" class="circuit-line"/>
      <line x1="160" y1="40" x2="130" y2="10" stroke="#a855f7" stroke-width="1" stroke-dasharray="4 4" class="circuit-line"/>
      <line x1="160" y1="40" x2="190" y2="10" stroke="#a855f7" stroke-width="1" stroke-dasharray="4 4" class="circuit-line"/>
      <circle cx="160" cy="40" r="3" fill="#a855f7"/>
      <circle cx="130" cy="10" r="3" fill="#a855f7"/>
      <circle cx="190" cy="10" r="3" fill="#a855f7"/>
      <!-- Bottom lines -->
      <line x1="160" y1="160" x2="160" y2="280" stroke="#a855f7" stroke-width="1" stroke-dasharray="4 4" class="circuit-line"/>
      <line x1="160" y1="280" x2="130" y2="310" stroke="#a855f7" stroke-width="1" stroke-dasharray="4 4" class="circuit-line"/>
      <line x1="160" y1="280" x2="190" y2="310" stroke="#a855f7" stroke-width="1" stroke-dasharray="4 4" class="circuit-line"/>
      <circle cx="160" cy="280" r="3" fill="#a855f7"/>
      <circle cx="130" cy="310" r="3" fill="#a855f7"/>
      <circle cx="190" cy="310" r="3" fill="#a855f7"/>
    </svg>

    <!-- Center glowing circle -->
    <div class="relative w-36 h-36 rounded-full border-2 border-purple-500 shadow-[0_0_40px_8px_rgba(168,85,247,0.4)] flex items-center justify-center bg-[#0a0713]">
      <div class="absolute inset-0 rounded-full bg-purple-500/10 animate-pulse"></div>
      <!-- Circuit chip icon -->
      <svg class="w-16 h-16 text-purple-400 relative z-10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="7" y="7" width="10" height="10" rx="1"/>
        <path d="M7 9H5M7 12H5M7 15H5M17 9h2M17 12h2M17 15h2M9 7V5M12 7V5M15 7V5M9 19v-2M12 19v-2M15 19v-2"/>
      </svg>
    </div>
  </div>

  <!-- Name -->
  <h1 id="boot-name" class="text-2xl sm:text-3xl font-bold text-white tracking-wide mb-1 opacity-0">Jamel Hadjirasul</h1>
  <p id="boot-label" class="text-purple-400/70 text-xs uppercase tracking-[0.25em] mb-8 opacity-0">Preparing digital space...</p>

  <!-- Progress bar -->
  <div class="w-64 sm:w-80">
    <div class="h-[3px] bg-white/10 rounded-full overflow-hidden">
      <div id="boot-bar" class="h-full rounded-full bg-gradient-to-r from-purple-500 to-cyan-400 w-0 transition-none shadow-[0_0_8px_rgba(168,85,247,0.8)]"></div>
    </div>
    <p id="boot-pct" class="text-center text-[10px] text-purple-300/50 uppercase tracking-widest mt-2">0% Loaded</p>
  </div>

</div>

<style>
  @keyframes boot-ring {
    0%, 100% { transform: scale(1); opacity: 0.4; }
    50% { transform: scale(1.06); opacity: 0.8; }
  }
  #boot-screen { transition: opacity 0.6s ease, visibility 0.6s ease; }
  #boot-screen.hidden-boot { opacity: 0; pointer-events: none; }
</style>

<script>
  // Only show boot screen once per browser session
  if (sessionStorage.getItem('booted')) {
    document.getElementById('boot-screen')?.remove();
  } else {
    sessionStorage.setItem('booted', '1');
  }

  // Generate random stars
  const starsEl = document.getElementById('boot-stars');
  if (starsEl) {
    for (let i = 0; i < 60; i++) {
      const s = document.createElement('div');
      const size = Math.random() * 2 + 1;
      s.style.cssText = `
        position:absolute;
        width:${size}px; height:${size}px;
        background:white;
        border-radius:50%;
        top:${Math.random()*100}%;
        left:${Math.random()*100}%;
        opacity:${Math.random()*0.5+0.1};
        animation: twinkle ${Math.random()*3+2}s ease-in-out infinite;
        animation-delay:${Math.random()*2}s;
      `;
      starsEl.appendChild(s);
    }
  }

  const boot = document.getElementById('boot-screen');
  const bar = document.getElementById('boot-bar');
  const pct = document.getElementById('boot-pct');
  const name = document.getElementById('boot-name');
  const label = document.getElementById('boot-label');

  // Fade in name & label
  setTimeout(() => {
    if (name) { name.style.transition = 'opacity 0.6s ease'; name.style.opacity = '1'; }
  }, 300);
  setTimeout(() => {
    if (label) { label.style.transition = 'opacity 0.6s ease'; label.style.opacity = '1'; }
  }, 600);

  // Animate progress bar
  let progress = 0;
  const steps = [
    { target: 30, delay: 200 },
    { target: 60, delay: 500 },
    { target: 85, delay: 400 },
    { target: 100, delay: 300 },
  ];

  let stepIndex = 0;
  function runStep() {
    if (stepIndex >= steps.length) return;
    const step = steps[stepIndex++];
    setTimeout(() => {
      progress = step.target;
      if (bar) { bar.style.transition = 'width 0.4s ease'; bar.style.width = `${progress}%`; }
      if (pct) pct.textContent = `${progress}% Loaded`;
      if (progress < 100) runStep();
      else {
        // Done — fade out
        setTimeout(() => {
          if (boot) boot.classList.add('hidden-boot');
          setTimeout(() => { boot?.remove(); }, 700);
        }, 400);
      }
    }, step.delay);
  }

  setTimeout(runStep, 800);
</script>

<style is:global>
  @keyframes twinkle {
    0%, 100% { opacity: 0.1; }
    50% { opacity: 0.6; }
  }
</style>
