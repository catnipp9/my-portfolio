---
---
<header id="main-header" class="fixed top-4 left-1/2 -translate-x-1/2 z-50 transition-all duration-500 w-[92%] max-w-5xl">
  <nav id="header-nav" class="flex items-center justify-between px-4 sm:px-6 py-2 rounded-full shadow-lg shadow-purple-900/40 bg-white/5 backdrop-blur-md border border-white/10 transition-all duration-500">
    <!-- Logo -->
    <a href="/" class="shrink-0 flex items-center">
      <img src="/logo-header.png" alt="Jamel Hadjirasul" class="h-9 w-auto object-contain" />
    </a>

    <!-- Nav links (desktop) -->
    <ul class="hidden md:flex gap-1 text-sm font-medium">
      <li>
        <a href="/#about" data-section="about" class="nav-link relative px-3 py-1.5 rounded-full text-purple-300/70 hover:text-purple-300 transition-colors">
          Home
        </a>
      </li>
      <li>
        <a href="/#skills" data-section="skills" class="nav-link relative px-3 py-1.5 rounded-full text-purple-300/70 hover:text-purple-300 transition-colors">
          Skills
        </a>
      </li>
      <li>
        <a href="/#work" data-section="work" class="nav-link relative px-3 py-1.5 rounded-full text-purple-300/70 hover:text-purple-300 transition-colors">
          Projects
        </a>
      </li>
      <li>
        <a href="/#awards" data-section="awards" class="nav-link relative px-3 py-1.5 rounded-full text-purple-300/70 hover:text-purple-300 transition-colors">
          Certifications
        </a>
      </li>
    </ul>

    <!-- CTA -->
    <a
      href="/contact"
      class="bg-purple-500 text-white px-4 sm:px-5 py-2 rounded-full text-xs font-bold hover:scale-105 hover:bg-purple-400 active:scale-95 transition-all shadow-md shadow-purple-500/30 shrink-0"
    >
      Get in Touch
    </a>
  </nav>
</header>

<script>
  const nav = document.getElementById('header-nav');

  // Scroll background swap
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      nav?.classList.add('bg-[#0d0a16]/90', 'border-purple-800/40');
      nav?.classList.remove('bg-white/5', 'border-white/10');
    } else {
      nav?.classList.remove('bg-[#0d0a16]/90', 'border-purple-800/40');
      nav?.classList.add('bg-white/5', 'border-white/10');
    }
  });

  // Active section highlight — only on the home page
  if (window.location.pathname === '/') {
    const sectionIds = ['about', 'skills', 'work', 'awards'];
    const links = document.querySelectorAll<HTMLAnchorElement>('.nav-link');

    function setActive(id: string) {
      links.forEach((link) => {
        const isActive = link.dataset.section === id;
        link.classList.toggle('text-purple-300', isActive);
        link.classList.toggle('bg-purple-800/40', isActive);
        link.classList.toggle('text-purple-300/70', !isActive);
      });
    }

    function onScroll() {
      if (window.scrollY < 50) {
        setActive(sectionIds[0]);
        return;
      }
      // Use getBoundingClientRect so React island offsetTop shifts don't matter
      const threshold = window.innerHeight * 0.5;
      let current = sectionIds[0];
      for (const id of sectionIds) {
        const el = document.getElementById(id);
        if (el && el.getBoundingClientRect().top <= threshold) current = id;
      }
      setActive(current);
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    setActive(sectionIds[0]);
  }
</script>
