---
export interface Props {
  title: string;
  category: string;
  desc: string;
  tags: string[];
  gradient: string;
  link?: string;
}
const { title, category, desc, tags, gradient, link = "#" } = Astro.props;
---
<a href={link} class="group cursor-pointer block">
  <div class={`aspect-[4/3] rounded-[3rem] bg-gradient-to-br ${gradient} mb-6 p-10 flex items-center justify-center overflow-hidden relative shadow-sm transition-all group-hover:shadow-2xl group-hover:shadow-purple-900/60 border border-purple-800/20`}>
    <div class="w-full h-full bg-white/5 backdrop-blur-md rounded-[2rem] flex items-center justify-center p-6 text-center border border-white/10">
      <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-purple-400 group-hover:scale-110 transition-transform"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
    </div>
    <div class="absolute top-6 right-6 w-12 h-12 bg-white/10 backdrop-blur rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all translate-y-4 group-hover:translate-y-0">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" x2="21" y1="14" y2="3"/></svg>
    </div>
  </div>
  <div class="px-4">
    <span class="text-xs font-bold text-purple-400 uppercase tracking-widest">{category}</span>
    <h3 class="text-2xl font-bold text-white mt-2 mb-3 group-hover:text-purple-300 transition-colors">{title}</h3>
    <p class="text-purple-200/50 mb-6 leading-relaxed line-clamp-2">{desc}</p>
    <div class="flex gap-2 flex-wrap">
      {tags.map(tag => (
        <span class="text-[10px] font-bold px-4 py-1.5 bg-white/5 border border-purple-800/50 text-purple-300/60 rounded-full group-hover:border-purple-600/50 group-hover:text-purple-300 transition-all">{tag}</span>
      ))}
    </div>
  </div>
</a>
