---
import SparkleButton from './SparkleButton.tsx';
---
<section
  id="about"
  class="min-h-[100dvh] flex flex-col items-center justify-center text-center px-4 pt-24 md:pt-28 pb-12 scroll-mt-32"
>
  <!-- Profile blob -->
  <div class="relative mb-7">
    <div class="w-48 h-48 sm:w-56 sm:h-56 md:w-64 md:h-64 p-2 bg-gradient-to-tr from-purple-500 to-indigo-500 animate-blob shadow-2xl shadow-purple-900/60">
      <div class="w-full h-full bg-[#0d0a16] animate-blob overflow-hidden border-4 border-purple-900/40">
        <img
          src="/profile-picture.jpg"
          alt="Jamel Hadjirasul"
          class="w-full h-full object-cover scale-110"
        />
      </div>
    </div>
    <div class="absolute -bottom-2 -right-2 animate-float">
      <SparkleButton client:load />
    </div>
  </div>

  <!-- Headline -->
  <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-extrabold text-white mb-5 tracking-tight leading-[1.1] max-w-4xl">
    Building digital experiences that
    <span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-violet-400">
      actually matter
    </span>
  </h1>

  <!-- Sub -->
  <p class="text-sm sm:text-base md:text-lg text-purple-200/55 max-w-lg mx-auto leading-relaxed mb-8">
    A Computer Engineering student dedicated to developing scalable full-stack applications and AI-driven systems that bridge complex logic with intuitive design
  </p>

  <!-- CTAs -->
  <div class="flex flex-wrap justify-center gap-3">
    <a
      href="/JamelHadjirasul_Resume.pdf"
      download
      class="px-6 py-3 bg-purple-500 text-white rounded-[3rem] font-bold hover:bg-purple-400 hover:shadow-xl hover:shadow-purple-500/30 transition-all flex items-center gap-2 group text-sm"
    >
      View my Resume
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-y-0.5 transition-transform"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
    </a>
    <a
      href="/about"
      class="px-6 py-3 bg-white/5 border border-purple-700/50 text-purple-300 rounded-[3rem] font-bold hover:bg-purple-900/40 hover:border-purple-500 transition-all flex items-center gap-2 text-sm"
    >
      All About Me
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
    </a>
    <div class="flex items-center gap-2">
      <a
        href="https://github.com/catnipp9"
        target="_blank"
        rel="noopener noreferrer"
        class="w-11 h-11 flex items-center justify-center bg-white/5 border border-purple-800/50 rounded-[3rem] text-purple-300/60 hover:text-purple-300 hover:border-purple-600 hover:bg-purple-900/30 transition-all"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
      </a>
      <a
        href="https://www.linkedin.com/in/jamel-hadjirasul-886a3a2a4/"
        target="_blank"
        rel="noopener noreferrer"
        class="w-11 h-11 flex items-center justify-center bg-white/5 border border-purple-800/50 rounded-[3rem] text-purple-300/60 hover:text-purple-300 hover:border-purple-600 hover:bg-purple-900/30 transition-all"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
      </a>
    </div>
  </div>

  <!-- Scroll hint -->
  <div class="mt-10 flex flex-col items-center text-purple-700 animate-bounce">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
  </div>
</section>
